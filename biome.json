{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noControlCharactersInRegex": "off",
        "noAssignInExpressions": "off"
      },
      "style": {
        "noNonNullAssertion": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!**/vscode-extension/out",
      "!**/coverage",
      "!**/docs",
      "!**/.claude/worktrees",
      "!dashboard"
    ]
  },
  "overrides": [
    {
      "includes": ["**/__tests__/**", "**/*.test.ts", "**/smoke-test.mjs"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noShadowRestrictedNames": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          },
          "complexity": {
            "noBannedTypes": "off",
            "noForEach": "off"
          }
        }
      }
    }
  ]
}
