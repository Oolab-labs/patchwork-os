{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PatchworkConfig",
  "type": "object",
  "required": ["model"],
  "properties": {
    "model": {
      "type": "string",
      "enum": ["claude", "openai", "gemini", "grok", "local"]
    },
    "defaultModel": { "type": "string" },
    "apiKeys": {
      "type": "object",
      "properties": {
        "anthropic": { "type": "string" },
        "openai": { "type": "string" },
        "google": { "type": "string" },
        "xai": { "type": "string" }
      },
      "additionalProperties": false
    },
    "localEndpoint": { "type": "string", "format": "uri" },
    "localModel": { "type": "string" },
    "localEmbeddingsEndpoint": { "type": "string", "format": "uri" },
    "localEmbeddingsModel": { "type": "string" },
    "dashboard": {
      "type": "object",
      "required": ["port", "requireApproval"],
      "properties": {
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "requireApproval": {
          "type": "array",
          "items": { "enum": ["low", "medium", "high"] }
        },
        "pushNotifications": { "type": "boolean" },
        "webhookUrl": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "recipesDir": { "type": "string" },
    "approvalGate": { "type": "string", "enum": ["off", "high", "all"] },
    "enableTimeOfDayAnomaly": { "type": "boolean" },
    "managedSettingsPath": { "type": "string" },
    "recipes": {
      "type": "object",
      "properties": {
        "disabled": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "driver": {
      "type": "string",
      "enum": [
        "subprocess",
        "api",
        "openai",
        "grok",
        "gemini",
        "gemini-api",
        "local",
        "none"
      ]
    },
    "notifications": {
      "type": "object",
      "properties": {
        "slackChannel": { "type": "string" }
      },
      "additionalProperties": false
    },
    "claudeBinary": { "type": "string" },
    "pushServiceUrl": { "type": "string", "format": "uri" },
    "pushServiceToken": { "type": "string" },
    "pushServiceBaseUrl": { "type": "string", "format": "uri" },
    "pushServiceAllowPrivate": { "type": "boolean" },
    "ntfyTopic": { "type": "string" },
    "ntfyServer": { "type": "string", "format": "uri" }
  },
  "additionalProperties": false
}
