# Copy to .env and fill in values before starting the relay.

# HTTP port (default 3001)
PORT=3001

# Auth tokens — comma-separated "token:userId" pairs.
# Each bridge user gets one entry. Token is the bearer token the bridge sends;
# userId routes to their registered devices.
RELAY_AUTH_TOKENS=changeme:user1

# Redis connection URL (optional — uses in-memory registry if absent)
# REDIS_URL=redis://localhost:6379

# FCM (Firebase Cloud Messaging) — for Android push
# Paste the full service account JSON as a single-line string
# FCM_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# APNS (Apple Push Notification Service) — for iOS push
# APNS_KEY=<contents of .p8 key file>
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=XXXXXXXXXX
# APNS_TOPIC=com.patchwork.app
# APNS_PRODUCTION=false
