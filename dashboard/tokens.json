{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "description": "Patchwork dashboard design tokens, mirrored from src/app/globals.css :root and [data-theme=\"dark\"] blocks. Drift is verified by `npm run tokens:check` (scripts/check-tokens.mjs).",
  "light": {
    "color": {
      "canvas":   "#f3efe5",
      "surface":  "#fbf8f0",
      "recess":   "#ece7d8",
      "pressed":  "#e0dac8",
      "line-1":   "rgba(60,45,20,0.10)",
      "line-2":   "rgba(60,45,20,0.18)",
      "line-3":   "rgba(60,45,20,0.28)",
      "ink-0":    "#2a2418",
      "ink-1":    "#4a4030",
      "ink-2":    "#6e6450",
      "ink-3":    "#9a907a",
      "orange":       "#c5532a",
      "orange-hover": "#ab4622",
      "orange-soft":  "rgba(197,83,42,0.13)",
      "orange-tint":  "rgba(197,83,42,0.24)",
      "orange-rgb":   "197, 83, 42",
      "accent-glow":  "rgba(197,83,42,0.28)",
      "purple":       "#7a5b9c",
      "purple-hover": "#684987",
      "purple-soft":  "rgba(122,91,156,0.14)",
      "green":        "#5b8a4f",
      "green-soft":   "rgba(91,138,79,0.15)",
      "amber":        "#c98e2b",
      "amber-soft":   "rgba(201,142,43,0.16)",
      "red":          "#b54343",
      "red-soft":     "rgba(181,67,67,0.14)",
      "blue":         "#4a6fa5",
      "blue-soft":    "rgba(74,111,165,0.14)",
      "accent":         "var(--orange)",
      "accent-hover":   "var(--orange-hover)",
      "accent-soft":    "var(--orange-soft)",
      "accent-tint":    "var(--orange-tint)",
      "accent-strong":  "#9d3f20"
    },
    "font": {
      "sans":  "var(--font-geist, \"Albert Sans\"), ui-sans-serif, \"SF Pro Text\", \"Segoe UI\", sans-serif",
      "serif": "var(--font-instrument-serif, \"Instrument Serif\"), ui-serif, Georgia, serif",
      "mono":  "var(--font-jetbrains, \"JetBrains Mono\"), ui-monospace, \"SF Mono\", Menlo, monospace"
    },
    "radius": {
      "s":    "6px",
      "m":    "10px",
      "l":    "14px",
      "xl":   "20px",
      "1":    "4px",
      "2":    "6px",
      "3":    "10px",
      "4":    "14px",
      "full": "999px",
      "default": "10px"
    },
    "shadow": {
      "s": "0 1px 3px rgba(42,36,24,.07), 0 1px 2px rgba(42,36,24,.04)",
      "m": "0 8px 24px rgba(42,36,24,.08), 0 2px 6px rgba(42,36,24,.04)",
      "l": "0 20px 50px rgba(42,36,24,.15), 0 5px 16px rgba(42,36,24,.07)"
    },
    "spacing": {
      "1":  "4px",
      "2":  "8px",
      "3":  "12px",
      "4":  "16px",
      "5":  "20px",
      "6":  "24px",
      "8":  "32px",
      "10": "40px",
      "12": "48px",
      "16": "64px"
    },
    "layout": {
      "nav-w":    "240px",
      "header-h": "56px",
      "transition": "cubic-bezier(0.4, 0, 0.2, 1)"
    }
  },
  "dark": {
    "color": {
      "canvas":  "#0a0b0d",
      "surface": "#101216",
      "recess":  "#15181d",
      "pressed": "#1c2026",
      "line-1":  "rgba(255,255,255,0.08)",
      "line-2":  "rgba(255,255,255,0.16)",
      "line-3":  "rgba(255,255,255,0.24)",
      "ink-0":   "#f6f7f8",
      "ink-1":   "#d4d6dc",
      "ink-2":   "#a3a7b1",
      "ink-3":   "#71757f",
      "orange":       "#ff7a45",
      "orange-hover": "#ff8f62",
      "orange-soft":  "rgba(255,122,69,0.14)",
      "orange-tint":  "rgba(255,122,69,0.25)",
      "orange-rgb":   "255, 122, 69",
      "accent-strong": "#e8956e",
      "accent-glow":   "rgba(255,122,69,0.35)",
      "purple-soft":  "#1c1b32",
      "green-soft":   "#0e2519",
      "amber-soft":   "#2b2110",
      "red-soft":     "#2b1511",
      "blue-soft":    "#101b2c"
    },
    "shadow": {
      "s": "0 1px 2px rgba(0,0,0,.25)",
      "m": "0 2px 5px rgba(0,0,0,.2), 0 1px 2px rgba(0,0,0,.12)"
    }
  }
}
