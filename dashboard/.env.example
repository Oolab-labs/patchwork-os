# Copy to .env.local and fill in values.

# Bridge port — auto-discovered from ~/.claude/ide/*.lock by default.
# Override here if you run the bridge on a non-standard port.
PATCHWORK_BRIDGE_PORT=3100

# Mobile push notifications (optional — enables PWA push + settings card)
# URL of the push relay service (services/push-relay/ or hosted at notify.patchwork.dev)
PUSH_RELAY_URL=https://notify.patchwork.dev
# Bearer token issued at Pro signup (or RELAY_AUTH_TOKENS entry for self-hosted relay)
PUSH_RELAY_TOKEN=
# VAPID public key for Web Push subscription (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
