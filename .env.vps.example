# VPS configuration for claude-ide-bridge startup script.
# Copy this file to .env.vps and fill in your values.
#   cp .env.vps.example .env.vps
#
# .env.vps is gitignored — safe to store secrets here.

# Port the bridge listens on (must match your ngrok tunnel)
PORT=9000

# Absolute path to the repo on the VPS
WORKSPACE=/root/claude-ide-bridge

# Fixed auth token — must match the token in your Claude MCP config
FIXED_TOKEN=your-token-here

# Optional: tmux session names (defaults shown)
BRIDGE_SESSION=bridge
NGROK_SESSION=ngrok

# Mobile push notifications (optional)
# URL of the push relay service; bridge POSTs here after queuing an approval
PATCHWORK_PUSH_URL=https://notify.patchwork.dev
# Bearer token for the relay service (issued at Pro signup)
PATCHWORK_PUSH_TOKEN=
# Public base URL of this bridge — embedded in push payload so the phone can call back
PATCHWORK_PUSH_BASE_URL=https://your-bridge-domain.example.com
