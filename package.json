{
  "name": "claude-ide-bridge",
  "version": "1.5.0",
  "description": "Standalone MCP bridge for Claude Code IDE integration with any editor — 120+ tools for LSP, debugging, terminals, Git, GitHub, and more",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-ide-bridge": "dist/index.js",
    "claude-ide-bridge-start": "dist/index.js"
  },
  "license": "MIT",
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "ide",
    "vscode",
    "lsp",
    "debugging",
    "terminal",
    "git",
    "github",
    "ai",
    "coding-assistant"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Oolab-labs/claude-ide-bridge"
  },
  "homepage": "https://github.com/Oolab-labs/claude-ide-bridge#readme",
  "bugs": {
    "url": "https://github.com/Oolab-labs/claude-ide-bridge/issues"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/**/__tests__",
    "scripts/start-all.sh",
    "scripts/start-remote.sh",
    "scripts/install-extension.sh",
    "scripts/gen-mcp-config.sh",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "remote": "bash scripts/start-remote.sh",
    "start-all": "bash scripts/start-all.sh"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
